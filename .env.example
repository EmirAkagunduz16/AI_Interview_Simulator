# ============================================
# AI Coach - Environment Variables
# ============================================
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun
# cp .env.example .env

# ============================================
# ZORUNLU API KEY'LER
# ============================================

# Gemini API Key - AI değerlendirme ve soru üretimi için
# https://aistudio.google.com/app/apikey adresinden alınabilir
GEMINI_API_KEY=your-gemini-api-key-here
# gemini-2.0-flash-exp deprecated; use gemini-1.5-flash or gemini-2.5-flash-preview-05-20
GEMINI_MODEL=gemini-1.5-flash

# ElevenLabs - Sesli AI mülakat asistanı
# https://elevenlabs.io adresinden alınabilir
# Agent ID - frontend'de de kullanılır (NEXT_PUBLIC) ve backend signed URL için
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=your-elevenlabs-agent-id-here
ELEVENLABS_AGENT_ID=your-elevenlabs-agent-id-here
# API Key - SADECE backend'de! Asla frontend'e koymayın. Özel agent için zorunlu.
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# ============================================
# KAFKA (Varsayılan Docker ayarları)
# ============================================

KAFKA_BROKERS=localhost:9092

# ============================================
# REDIS (Varsayılan Docker ayarları)
# ============================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis123

# ============================================
# SERVİS PORTLARI
# ============================================

# API Gateway
API_GATEWAY_PORT=3001

# Interview Service
INTERVIEW_SERVICE_PORT=3005

# AI Service
AI_SERVICE_PORT=3006

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001/api
