# ============================================
# AI Coach - Environment Variables
# ============================================
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun
# cp .env.example .env

# ============================================
# ZORUNLU API KEY'LER
# ============================================

# Gemini API Key - AI değerlendirme ve soru üretimi için
# https://aistudio.google.com/app/apikey adresinden alınabilir
GEMINI_API_KEY=your-gemini-api-key-here
# gemini-2.0-flash-exp deprecated; use gemini-1.5-flash or gemini-2.5-flash-preview-05-20
GEMINI_MODEL=gemini-1.5-flash

# ElevenLabs - Sesli AI mülakat asistanı
# https://elevenlabs.io adresinden alınabilir
# Agent ID - frontend'de de kullanılır (NEXT_PUBLIC) ve backend signed URL için
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=your-elevenlabs-agent-id-here
ELEVENLABS_AGENT_ID=your-elevenlabs-agent-id-here
# API Key - SADECE backend'de! Asla frontend'e koymayın. Özel agent için zorunlu.
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# --- ElevenLabs oturum (ses kalitesi / güvenli bağlantı) ---
# Özel (private) agent: imzalı URL kullanın. Kapalı ise public agent ile doğrudan agentId yeterlidir.
# Signed URL ile bağlanırken SDK yalnızca WebSocket kabul eder; WebRTC kapalı kalır.
NEXT_PUBLIC_ELEVENLABS_USE_SIGNED_URL=false

# WebRTC (LiveKit) — genelde websocket akışına göre daha akıcı ses; ağ UDP’ye izin vermeli.
# true: agentId ile doğrudan bağlantıda webrtc | false veya unset: websocket (varsayılan)
# İmzalı URL (USE_SIGNED_URL=true) kullanıyorsanız bu bayrak yok sayılır (her zaman websocket).
NEXT_PUBLIC_ELEVENLABS_USE_WEBRTC=false

# Konuşma / STT dil kodu (SDK overrides.agent.language). Türkçe + İngilizce terim karışımı için genelde `tr`.
# Agent panelinde dil ayrıca ayarlıysa çakışmayı kontrol edin.
NEXT_PUBLIC_ELEVENLABS_AGENT_LANGUAGE=tr

# ElevenLabs panelinde (önerilir): Agent → speech / Scribe tarafında keyterms veya telaffuz sözlüğü
# kullanarak ürün adlarınızı tanımlamak, istemeden uzayan statik düzeltme listelerinden daha etkilidir.

# --- Sesli mülakat davranışı (Next.js / tarayıcı) ---
# true: Agent “speaking” modundayken mikrofona sessizlik gönderir (hoparlör yankısında sahte VAD’yi azaltır).
# Öneri: varsayılan kapalı (satırı yazmayın veya false). Ajan sizi kesiyor/geç duyuyorsa KAPALI tutun; kulaklık kullanın.
# Sadece hoparlör + sürekli yanlış kesinti yaşıyorsanız true yapın.
NEXT_PUBLIC_VOICE_SUPPRESS_MIC_WHILE_AGENT_SPEAKS=false

# Yukarıdaki true ise: “listening”e geçişten kaç ms sonra mikrofonu aç (yankı kuyruğu). Varsayılan 280 ms.
# NEXT_PUBLIC_VOICE_POST_AGENT_SPEECH_MS=400

# ============================================
# KAFKA (Varsayılan Docker ayarları)
# ============================================

KAFKA_BROKERS=localhost:9092

# ============================================
# REDIS (Varsayılan Docker ayarları)
# ============================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis123

# ============================================
# SERVİS PORTLARI
# ============================================

# API Gateway
API_GATEWAY_PORT=3001

# Interview Service
INTERVIEW_SERVICE_PORT=3005

# AI Service
AI_SERVICE_PORT=3006

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001/api
